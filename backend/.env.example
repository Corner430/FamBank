# FamBank Backend Configuration
# 两种方式任选其一：

# ---- 方式一：完整连接字符串 ----
# DATABASE_URL=mysql+aiomysql://fambank:fambank@localhost:3306/fambank

# ---- 方式二：拆分字段（推荐，适合云数据库）----
DB_HOST=localhost
DB_PORT=3306
DB_USER=fambank
DB_PASSWORD=fambank
DB_NAME=fambank

# JWT 签名密钥（生产环境必须修改为随机长字符串）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=fambank-dev-only-change-in-production

# 日志级别
LOG_LEVEL=INFO

# 测试数据库（仅开发时需要）
TEST_DATABASE_URL=mysql+aiomysql://fambank:fambank@localhost:3306/fambank_test
