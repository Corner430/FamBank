/* Global Styles - FamBank */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

/* Container */
.container {
  padding: 20rpx 30rpx;
}

/* Card */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* Form */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4A90D9;
}

/* Buttons */
.btn-primary {
  background: #4A90D9;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}

.btn-primary[disabled] {
  background: #b0c4de;
}

.btn-secondary {
  background: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}

.btn-danger {
  background: #e74c3c;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}

.btn-small {
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
  display: inline-block;
  width: auto;
}

/* Typography */
.text-primary { color: #4A90D9; }
.text-success { color: #27ae60; }
.text-danger { color: #e74c3c; }
.text-warning { color: #f39c12; }
.text-muted { color: #999999; }
.text-bold { font-weight: 600; }
.text-large { font-size: 36rpx; }
.text-small { font-size: 24rpx; }
.text-center { text-align: center; }

/* Amount display */
.amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
}

.amount-unit {
  font-size: 26rpx;
  font-weight: 400;
  color: #999999;
  margin-left: 4rpx;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ffffff;
}

.badge-parent { background: #4A90D9; }
.badge-child { background: #27ae60; }
.badge-pending { background: #f39c12; }

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999999;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
}

/* Divider */
.divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 20rpx 0;
}

/* List */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

/* Section header */
.section-header {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* Account type colors */
.account-a { border-left: 6rpx solid #4A90D9; }
.account-b { border-left: 6rpx solid #27ae60; }
.account-c { border-left: 6rpx solid #9b59b6; }

/* Picker */
.picker {
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

/* Toast/message area */
.toast-message {
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}

.toast-success {
  background: #d4edda;
  color: #155724;
}

.toast-error {
  background: #f8d7da;
  color: #721c24;
}

/* Flex utilities */
.flex { display: flex; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* Spacing */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }
