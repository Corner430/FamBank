.onboarding-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Choose Mode */
.choose-container {
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #999;
}

.choose-cards {
  width: 100%;
}

.choose-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.choose-card:active {
  transform: scale(0.98);
}

.choose-card-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.choose-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.choose-card-desc {
  font-size: 26rpx;
  color: #999;
}

/* Form Mode */
.form-container {
  padding: 60rpx 40rpx;
}

.form-header {
  margin-bottom: 40rpx;
}

.form-header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.form-header-desc {
  font-size: 28rpx;
  color: #999;
}

.invite-code-input {
  letter-spacing: 12rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
}

.back-link {
  text-align: center;
  color: #4A90D9;
  font-size: 28rpx;
  margin-top: 40rpx;
  padding: 20rpx;
}
