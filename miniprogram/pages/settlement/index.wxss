/* Settlement page styles */
.execute-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.settlement-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.settlement-row:last-child {
  border-bottom: none;
}

.settlement-details {
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8f9fa;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  min-width: 140rpx;
}
