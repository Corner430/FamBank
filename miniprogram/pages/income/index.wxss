/* Amount Input */
.amount-input {
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  height: 100rpx;
}

/* Result Section */
.result-section {
  padding-top: 20rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #27ae60;
}

/* Split Rows */
.split-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.split-label {
  display: flex;
  align-items: center;
}

.split-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-a {
  background: #4A90D9;
}

.dot-b {
  background: #27ae60;
}

.dot-c {
  background: #9b59b6;
}
