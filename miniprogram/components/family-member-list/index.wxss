.member-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.member-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.role-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.role-badge.parent {
  background-color: rgba(74, 144, 217, 0.12);
}

.role-badge.child {
  background-color: rgba(39, 174, 96, 0.12);
}

.role-badge-text {
  font-size: 22rpx;
}

.role-badge.parent .role-badge-text {
  color: #4A90D9;
}

.role-badge.child .role-badge-text {
  color: #27ae60;
}

.empty-tip {
  padding: 48rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}
