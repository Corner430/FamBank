.child-selector {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
}

.child-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background-color: #f5f5f5;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.child-chip.selected {
  background-color: rgba(74, 144, 217, 0.12);
  border-color: #4A90D9;
}

.child-chip-text {
  font-size: 28rpx;
  color: #666666;
}

.child-chip.selected .child-chip-text {
  color: #4A90D9;
  font-weight: 500;
}
