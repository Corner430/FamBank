.invitation-manager {
  padding: 0;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
  background-color: #4A90D9;
  border-radius: 12rpx;
}

.create-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* Create form */
.create-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  width: 100rpx;
  flex-shrink: 0;
}

.role-picker {
  display: flex;
  gap: 32rpx;
}

.role-option {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
}

.role-option text {
  margin-left: 8rpx;
}

.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.confirm-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  background-color: #27ae60;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.confirm-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* Invitation list */
.invitation-list {
  margin-top: 8rpx;
}

.invitation-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.invitation-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.code-area {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.code-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
  font-family: monospace;
}

.copy-hint {
  font-size: 20rpx;
  color: #4A90D9;
}

/* Status badges */
.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-pending {
  background-color: rgba(243, 156, 18, 0.12);
}

.status-used {
  background-color: rgba(39, 174, 96, 0.12);
}

.status-revoked {
  background-color: rgba(231, 76, 60, 0.12);
}

.status-expired {
  background-color: rgba(153, 153, 153, 0.12);
}

.status-text {
  font-size: 22rpx;
}

.status-pending .status-text {
  color: #f39c12;
}

.status-used .status-text {
  color: #27ae60;
}

.status-revoked .status-text {
  color: #e74c3c;
}

.status-expired .status-text {
  color: #999999;
}

.invitation-detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #666666;
}

.detail-expiry {
  font-size: 22rpx;
  color: #999999;
}

.revoke-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 8rpx;
}

.revoke-btn-text {
  font-size: 24rpx;
  color: #e74c3c;
}

.empty-tip {
  padding: 48rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}
